# ===========================================
# Portfolio — Environment Variables
# ===========================================
# Copy to .env and fill in your values:
#   cp .env.example .env

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql://user:password@host:5432/portfolio

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Session / Auth ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# --- Admin Setup (Optional) ---
# Default password for admin user during initial setup
# If not set, a random password will be generated
# ADMIN_DEFAULT_PASSWORD=your-secure-password-here

# --- Deployment / Mock Mode ---
# Set to 'true' to use mock data in the frontend even if API is available
VITE_USE_MOCK_DATA=false
# Set to 'mock' to use in-memory storage, 'db' to use PostgreSQL
STORAGE_TYPE=db
